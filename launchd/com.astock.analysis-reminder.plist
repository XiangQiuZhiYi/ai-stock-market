<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.astock.analysis-reminder</string>

  <key>ProgramArguments</key>
  <array>
    <string>/ABSOLUTE/PATH/TO/astock/.venv/bin/python</string>
    <string>/ABSOLUTE/PATH/TO/astock/notify_analysis.py</string>
    <string>auto</string>
  </array>

  <key>StartCalendarInterval</key>
  <array>
    <dict>
      <key>Hour</key>
      <integer>10</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
    <dict>
      <key>Hour</key>
      <integer>11</integer>
      <key>Minute</key>
      <integer>25</integer>
    </dict>
    <dict>
      <key>Hour</key>
      <integer>14</integer>
      <key>Minute</key>
      <integer>50</integer>
    </dict>
  </array>

  <key>RunAtLoad</key>
  <false/>

  <!-- 记录输出，便于排查 plist 或脚本路径配置问题。 -->
  <key>StandardOutPath</key>
  <string>/tmp/astock-analysis-reminder.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/astock-analysis-reminder.err</string>
</dict>
</plist>
